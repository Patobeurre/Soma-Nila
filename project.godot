[internationalization]

locale/translations=PackedStringArray("res://scripts/resources/translation/placeable_objects.en.translation", "res://scripts/resources/translation/placeable_objects.fr.translation", "res://scripts/resources/translation/menus.en.translation", "res://scripts/resources/translation/menus.fr.translation")

[layer_names]

3d_render/layer_1="Calque 1"
3d_render/layer_2="Calque 2"
3d_physics/layer_1="Walls"
3d_physics/layer_2="Player"
3d_physics/layer_3="BreakableObject"
3d_physics/layer_4="Interactable"
3d_physics/layer_5="Collectable"
3d_physics/layer_13="MovableObject"

[physics]

common/physics_ticks_per_second=120
3d/physics_engine="Jolt Physics"
jolt_physics_3d/simulation/areas_detect_static_bodies=true
jolt_physics_3d/limits/max_bodies=20480

[rendering]

textures/canvas_textures/default_texture_filter=2
textures/lossless_compression/force_png=true
lights_and_shadows/directional_shadow/16_bits=false
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=3
global_illumination/gi/use_half_resolution=true
textures/default_filters/use_nearest_mipmap_filter=true
anti_aliasing/quality/msaa_2d=2
anti_aliasing/quality/msaa_3d=2
mesh_lod/lod_change/threshold_pixels=0.5
camera/depth_of_field/fov=90.0

; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Soma Nila"
config/version="1.0"
run/main_scene="uid://c1nji1bcaxwdp"
config/features=PackedStringArray("4.4", "GL Compatibility")
run/max_fps=120
boot_splash/show_image=false
config/icon="uid://dygawtjpp3132"
config/windows_native_icon="res://images/strawberry_icon.ico"

[autoload]

Utils="*res://scripts/global/Utils.gd"
Global="*res://scripts/global/Global.gd"
SignalBus="*res://scripts/global/SignalBus.gd"
SaveManager="*res://scripts/global/SaveManager.gd"
BbCodeString="*res://scripts/global/BBCodeString.gd"
CameraTransition="*res://camera_transition.tscn"
AudioBus="*res://scripts/global/audio_bus.tscn"
InputKeyImageMapper="*res://scripts/global/InputKeyImageMapper.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
mouse_cursor/custom_image="uid://cunmjqxq70v8j"
mouse_cursor/mouse_sensitivity=Vector2(0.5, 0.5)

[editor_plugins]

enabled=PackedStringArray("res://addons/finite_state_machine/plugin.cfg")

[importer_defaults]

csv_translation={
"compress": true,
"delimiter": 0
}

